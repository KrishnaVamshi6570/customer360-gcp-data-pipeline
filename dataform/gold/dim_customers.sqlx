config {
  type: "table",
  schema: "gold_marts",
  name: "dim_customers"
}

SELECT
  customer_id,
  customer_unique_id,
  customer_city,
  customer_state,
  MIN(ingestion_timestamp) AS first_seen_timestamp
FROM ${ref("silver_customers")}
GROUP BY
  customer_id,
  customer_unique_id,
  customer_city,
  customer_state